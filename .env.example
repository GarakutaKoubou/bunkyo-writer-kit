# ── Google Drive / Docs 保存先 ──────────────────────────────────────────────
# 横山から受け取る値をそのまま貼り付けてください

GDOCS_FOLDER_ID=your_gdocs_folder_id_here
COMPLETED_FOLDER_ID=your_completed_folder_id_here
YEAR_FOLDERS_PARENT_ID=your_year_folders_parent_id_here

# ── Google Sheets 記事インデックス ───────────────────────────────────────────
SHEETS_INDEX_ID=your_sheets_id_here

# ── ライター名（自分の名前を入力） ───────────────────────────────────────────
# setup.sh を実行すると自動で設定されます
WRITER_NAME=横山

# ── 以下は横山専用（ライターは不要） ─────────────────────────────────────────
# NOTION_TOKEN=
# NOTION_DATABASE_ID=
# NOTION_INDEX_PAGE_ID=
# SENDGRID_API_KEY=
# GEMINI_API_KEY=
